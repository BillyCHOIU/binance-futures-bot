# 复制本文件为 .env 后填入（不要把 .env 发给任何人）
# API 权限：只开「合约交易」，禁止开启提现

BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = 币安合约测试网；false = 实盘（谨慎）
USE_TESTNET=true

# ---------- 舆情（可选，解决 Reddit 403 / 接入 X）----------

# 方案 A：系统代理（Clash/V2 等开系统代理后一般可填）
# 例: http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
# 或专用：
FLUXBOT_PROXY=

# 方案 B：Reddit 官方 API（https://www.reddit.com/prefs/apps 创建 script 类型）
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FluxBot/0.1 by your_reddit_username

# 方案 C：X (Twitter) API Bearer Token（https://developer.x.com）
X_BEARER_TOKEN=

# 方案 D：CryptoPanic（https://cryptopanic.com/developers/api/ 免费档）
CRYPTOPANIC_TOKEN=
